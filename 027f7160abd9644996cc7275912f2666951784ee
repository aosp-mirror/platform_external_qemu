    {
      "key": {
        "uuid": "4f3d64bd_1e404715",
        "filename": "android-qemu2-glue/main.cpp",
        "patchSetId": 4
      },
      "lineNbr": 1420,
      "author": {
        "id": 1082465
      },
      "writtenOn": "2018-08-18T21:12:37Z",
      "side": 1,
      "message": "This might be fragile to -wipe-data and attempt to edit files in the AVD directory. Do we really want to do this for all kernel parameters?",
      "range": {
        "startLine": 1417,
        "startChar": 0,
        "endLine": 1420,
        "endChar": 0
      },
      "revId": "027f7160abd9644996cc7275912f2666951784ee",
