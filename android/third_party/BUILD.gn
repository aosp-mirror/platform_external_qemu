# libcurl
config("libcurl") {
  defines = [
    "CURL_STATICLIB",
  ]

  ldflags = [
    rebase_path("$LIBCURL_PREBUILTS_DIR/$BUILD_TARGET_TAG/lib/libcurl.a", root_build_dir),
  ]

  if (is_win) {
     ldflags += [
      "-lcrypt32",
      "-lgdi32",
    ]
  } else {
    ldflags += [
      "-ldl",
    ]
  }

  include_dirs = [
    "$LIBCURL_PREBUILTS_DIR/$BUILD_TARGET_TAG/include",
  ]
}

