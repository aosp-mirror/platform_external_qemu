     ldflags = [
      "-lcrypt32",
      "-lgdi32",
    ]
  } else {
    ldflags = [
      "-ldl",
    ]
  }

  libs = [
    "curl",
    "ssl",
    "crypto",
    "z",
  ]

  lib_dirs = [
    "$LIBCURL_PREBUILTS_DIR/$BUILD_TARGET_TAG/lib",
  ]

  include_dirs = [
    "$LIBCURL_PREBUILTS_DIR/$BUILD_TARGET_TAG/include",
  ]
}

