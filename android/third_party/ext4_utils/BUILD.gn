import("//external/qemu/android/config.gni")

config("emulator-libext4_utils_config") {
  include_dirs = [
    "include",
  ]
}

static_library("emulator-libext4_utils") {
  sources = [
    "src/allocate.c",
    "src/contents.c",
    "src/crc16.c",
    "src/ext4_sb.c",
    "src/ext4_utils.c",
    "src/extent.c",
    "src/fs_config.c",
    "src/indirect.c",
    "src/make_ext4fs.c",
    "src/sha1.c",
    "src/uuid.c",
    "src/wipe.c",
  ]

  cflags = [
    "-DHOST",
    "-Wno-error",
  ]

  if (is_win) {
    cflags += [
      "-DUSE_MINGW=1",
    ]
  }

  configs += [
    "//external/qemu/android/third_party:zlib",
  ]

  deps = [
    "//external/qemu/android/third_party/libselinux:emulator-libselinux",
    "//external/qemu/android/third_party/libsparse:emulator-libsparse",
  ]

  if (is_win) {
    deps = [
      "//external/qemu/android/third_party/mman-win32:emulator-libmman-win32",
    ]
  }

  public_configs = [ ":emulator-libext4_utils_config" ]
}

executable("emulator$BUILD_TARGET_SUFFIX" + "_make_ext4fs") {
  sources = [
    "src/make_ext4fs_main.c", 
  ]

  cflags = [
    "-DHOST",
    "-Wno-error",
  ]

  if (is_win) {
    cflags += [
      "-DUSE_MINGW=1",
    ]
  }

  deps = [
    ":emulator-libext4_utils",
    "//external/qemu/android/third_party/libselinux:emulator-libselinux",
  ]
}

