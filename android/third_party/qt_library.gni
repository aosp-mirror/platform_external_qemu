# qt_library.gni
# refer to third_party/protobuf/proto_library.gni

# Invoke Qt moc tool to generate .moc files
# The generated files are provided as a source_set that can be used as dep
# for other projects
#

# parameters:
#
#   moc_in_dir (optional)
#       Specifies the path relative to the current BUILD.gn file where
#       moc cpp files are located and the directory structure of
#       this library starts.
#
#       This option can be calculated automatically but it will raise an
#       assertion error if any nested directories are found.
#
#   moc_out_dir (optional)
#       Specifies the path suffix that output files are generated under.
#       This path will be appended to |root_gen_dir|.
#   cc_include (optional)
#       String listing an extra include that should be passed.
#       Example: cc_include = "foo/bar.h"

# Example:
#  qt_library("mylib") {
#    sources = [
#      "foo.h",
#    ]
#  }

import("//build/config/sanitizers/sanitizers.gni")
import("../config.gni")

QT_TOP_DIR = "$QT_PREBUILTS_DIR/$BUILD_TARGET_TAG"
QT_TOP64_DIR = "$QT_PREBUILTS_DIR/$BUILD_TARGET_OS-x86_64"
QT_MOC_TOOL = "$QT_TOP64_DIR/bin/moc"
QT_RCC_TOOL = "$QT_TOP64_DIR/bin/rcc"

# Special-case: the 'uic' tool depends on Qt5Core: always ensure that the
# version that is being used is from the prebuilts directory. Otherwise
# the executable may fail to start due to dynamic linking problems.
QT_UIC_TOOL_LDPATH = "$QT_TOP64_DIR/lib"
QT_UIC_TOOL = "$QT_TOP64_DIR/bin/uic"

template("qt_library") {
  assert(defined(!invoker.sources) && !defined(invoker.ui_sources) &&
      !defined(invoker.resources),
      "Need sources, ui_sources or resources for qt_library")

  moc_sources = invoker.sources

  # Don't apply OS-specific sources filtering to the assignments later on.
  # Platform files should have gotten filtered out in the sources assignment
  # when this template was invoked. If they weren't, it was on purpose and
  # this template shouldn't re-apply the filter.
  set_sources_assignment_filter([])

  if (host_os == "win") {
    host_executable_suffix = ".exe"
  } else {
    host_executable_suffix = ""
  }

  if (defined(invoker.moc_in_dir)) {
    moc_in_dir = invoker.moc_in_dir
    has_nested_dirs = false
    foreach(moc_source, moc_sources) {
      if (get_path_info(moc_source, "dir") != moc_in_dir) {
        has_nested_dirs = true
      }
    }
  } else {
    moc_in_dir = get_path_info(moc_sources[0], "dir")
    has_nested_dirs = false

    # Sanity check, |moc_in_dir| should be defined to allow sub-directories.
    foreach(moc_source, moc_sources) {
      assert(get_path_info(moc_source, "dir") == moc_in_dir,
             "Please define |moc_in_dir| to allow nested directories.")
    }
  }

  # Avoid absolute path because of the assumption that |moc_in_dir| is
  # relative to the directory of current BUILD.gn file.
  moc_in_dir = rebase_path(moc_in_dir, ".")

  if (defined(invoker.moc_out_dir)) {
    moc_out_dir = invoker.moc_out_dir
  } else {
    # Absolute path to the directory of current BUILD.gn file excluding "//".
    moc_out_dir = rebase_path(".", "//")
    if (moc_in_dir != ".") {
      moc_out_dir += "/$moc_in_dir"
    }
  }

  # We need both absolute path to use in GN statements and a relative one
  # to pass to external script.
  cc_out_dir = "$root_gen_dir/" + moc_out_dir
  rel_cc_out_dir = rebase_path(cc_out_dir, root_build_dir)

  header_files = rebase_path(invoker.sources, moc_in_dir)
  mocgens = []

  # List output files.
  foreach(header, header_files) {
    header_dir = get_path_info(header, "dir")
    header_name = get_path_info(header, "name")
    header_path = header_dir + "/" + header_name

    mocgens += [
      "$cc_out_dir/$header_path.cpp",
    ]
  }

  action_name = "${target_name}_gen"
  source_set_name = target_name

  # Generate moc cpp files.
  action(action_name) {
    visibility = [ ":$source_set_name" ]
    script = "qt_wrapper.py"
    sources = moc_sources
    outputs = get_path_info(mocgens, "abspath")
    args = header_files

    moc_path = get_path_info(QT_MOC_TOOL) + host_executable_suffix
    args += [
      # Wrapper should never pick a system moc.
      # Path should be rebased because |root_build_dir| for current toolchain
      # may be different from |root_out_dir| of moc built on host toolchain.
      "--moc",
      "./" + rebase_path(moc_path, root_build_dir),
      "--moc-in-dir",
      rebase_path(moc_in_dir, root_build_dir),
    ]

    args += [
      "--cc-out-dir",
      rel_cc_out_dir,
    ]

    if (defined(invoker.cc_include)) {
      args += [
        "--include",
        invoker.cc_include,
      ]
    }

    if (defined(invoker.deps)) {
      # The deps may have steps that have to run before running moc.
      deps += invoker.deps
    }
  }

  # Generated files may include other generated headers. These includes always
  # use relative paths starting at |cc_out_dir|.
  # However there is no necessity to add an additional directory, if all headers
  # are located in the same directory which is in the search path by default.
  if (has_nested_dirs) {
    config_name = "${target_name}_config"
    config(config_name) {
      include_dirs = [ cc_out_dir ]
    }
  }

  # Build generated moc cpp stubs as source set.
  target("source_set", target_name) {
    forward_variables_from(invoker,
                           [
                             "defines",
                             "testonly",
                             "visibility",
                           ])

    sources = get_target_outputs(":$action_name")

    if (defined(invoker.extra_configs)) {
      configs += invoker.extra_configs
    }

    deps = [
      ":$action_name",
    ]

    # This will link any libraries in the deps (the use of invoker.deps in the
    # action won't link it).
    if (defined(invoker.deps)) {
      deps += invoker.deps
    }
  }
}

