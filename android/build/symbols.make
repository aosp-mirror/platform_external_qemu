INTERMEDIATE_BUILT_MODULE_SYM:= $(INTERMEDIATE_BUILT_MODULE).sym
$(INTERMEDIATE_BUILT_MODULE_SYM): PRIVATE_SYMTOOL := $(LOCAL_SYMTOOL)
$(INTERMEDIATE_BUILT_MODULE_SYM): $(INTERMEDIATE_BUILT_MODULE)
	@ echo "Symbol file: $@"
	@ $(PRIVATE_SYMTOOL) $< > $@ && \
	SYMB_CODE=`head -n1 $@ | cut -d" " -f4` && \
	SYMB_NAME=`head -n1 $@ | cut -d" " -f5` && \
	mkdir -p $(SYMBOLS_DIR)/$$SYMB_NAME/$$SYMB_CODE && \
	cp $@ $(SYMBOLS_DIR)/$$SYMB_NAME/$$SYMB_CODE

$(if $(LOCAL_GENERATE_SYMBOLS), $(eval SYMBOLS+=$(INTERMEDIATE_BUILT_MODULE_SYM)))
