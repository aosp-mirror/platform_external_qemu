import("//android/config.gni")

shared_library("lib$BUILD_TARGET_SUFFIX" + "EGL_translator") {
  sources = [
    "ThreadInfo.cpp",
    "EglImp.cpp",
    "EglConfig.cpp",
    "EglContext.cpp",
    "EglGlobalInfo.cpp",
    "EglValidate.cpp",
    "EglSurface.cpp",
    "EglWindowSurface.cpp",
    "EglPbufferSurface.cpp",
    "EglThreadInfo.cpp",
    "EglDisplay.cpp",
    "ClientAPIExts.cpp",
  ]

  if (is_linux) {
    sources += [
      "EglOsApi_glx.cpp",
      "EglOsApi_egl.cpp",
      "CoreProfileConfigs_linux.cpp",
    ]

    ldflags = [
      "-lGL",
      "-lX11",
      "-ldl",
      "-lpthread",
    ]
  }

  if (is_mac) {
    sources += [
      "EglOsApi_darwin.cpp",
      "EglOsApi_egl.cpp",
      "MacNative.m",
      "MacPixelFormatsAttribs.m",
    ]

    ldflags = [
      "-Wl",
      "-framework,AppKit",
    ]
  }

  if (is_win) {
    sources += [
      "EglOsApi_wgl.cpp",
      "EglOsApi_egl.cpp",
      "CoreProfileConfigs_windows.cpp",
    ]

    ldflags = [
      "-lgdi32",
    ]
  }

  output_dir = "$root_out_dir/lib64"

  include_dirs = [
    ".",
    "../include",
    "//android/android-emu",
    "//android/android-emugl/host/include",
    "//android/android-emugl/shared",
  ]

  deps = [
    "//build/config:exe_and_shlib_deps",
    "//build/win:default_exe_manifest",
    "//android/android-emu:android-emu-base",
    "//android/android-emugl/host/libs/Translator/GLcommon:libGLcommon",
    "//android/android-emugl/shared/emugl/common:libemugl_common",
  ]
}
