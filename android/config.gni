# modified from objs/build/config.make, which is generated by configure.sh

BUILD_TARGET_OS    = "linux"
BUILD_TARGET_ARCH  = "x86_64"

CONFIG_COREAUDIO  = "no"
CONFIG_WINAUDIO   = "no"
CONFIG_ESD        = "yes"
CONFIG_ALSA       = "yes"
CONFIG_OSS        = "yes"
CONFIG_PULSEAUDIO = "yes"

PREBUILTS_DIR = "//prebuilts"
QT_PREBUILTS_DIR  = "$PREBUILTS_DIR/android-emulator-build/qt"
EMULATOR_USE_ANGLE = false
COMMON_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common"
ZLIB_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/qemu-android-deps"
LIBPNG_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/qemu-android-deps"
LIBSDL2_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/qemu-android-deps"
LIBXML2_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/libxml2"
LIBCURL_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/curl"
ANGLE_TRANSLATION_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/ANGLE"
BREAKPAD_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/breakpad"
LIBUUID_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/e2fsprogs"
PROTOBUF_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/protobuf"
LZ4_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/lz4"
FFMPEG_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/ffmpeg"
X264_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/x264"
LIBVPX_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/libvpx"
LIBBLUEZ_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/bluez"
LIBUSB_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/common/libusb"
BUILD_STRIP_BINARIES = "true"
EMULATOR_CRASHUPLOAD = "NONE"
ANDROID_SDK_TOOLS_CL_SHA1 = "14a0de02eba0f69fd740724e91e3a27d0da2d724"
QEMU2_TOP_DIR = "//external/qemu"

QEMU2_DEPS_PREBUILTS_DIR = "$PREBUILTS_DIR/android-emulator-build/qemu-android-deps"

#PROTOC_TOOL = "$PROTOBUF_PREBUILTS_DIR/$BUILD_HOST_TAG64/bin/protoc"


BUILD_EMUGL_PRINTOUT = "false"

BUILD_DEBUG = "false"

# from build/Makefile.common.mk

EMULATOR_COMMON_CFLAGS = [
  "-Werror=implicit-function-declaration",
  "-D_GNU_SOURCE=1"
]

# Include the emulator version definition from Makefile.common.mk
#EMULATOR_COMMON_CFLAGS += [$EMULATOR_VERSION_CFLAGS]

if (BUILD_DEBUG == "true") {
    EMULATOR_COMMON_CFLAGS += ["-DENABLE_DLOG=1"]
} else {
    EMULATOR_COMMON_CFLAGS += ["-DENABLE_DLOG=0"]
}

if (EMULATOR_CRASHUPLOAD != "") {
    EMULATOR_COMMON_CFLAGS += ["-DCRASHUPLOAD=$EMULATOR_CRASHUPLOAD"]
}

BUILD_TARGET_TAG  = "$BUILD_TARGET_OS-$BUILD_TARGET_ARCH"
EMULATOR_VERSION_CFLAGS = ""

# $(BUILD_OBJS_DIR)/build is required to access config-host.h
# $(generated-proto-sources-dir) is needed to access generated
# protobuff headers.
#EMULATOR_COMMON_INCLUDES = [
#  "$BUILD_OBJS_DIR/build",
#  generated-proto-sources-dir,
#  LIBMMAN_WIN32_INCLUDES,
#  PICOSHA2_INCLUDES,
#]

EMUGL_SRCDIR = "//external/qemu/android/android-emugl"
EMUGL_INCLUDES = "$EMUGL_SRCDIR/host/include"
if (BUILD_EMUGL_PRINTOUT == "true") {
  EMUGL_USER_CFLAGS = "-DOPENGL_DEBUG_PRINTOUT"
} else {
  EMUGL_USER_CFLAGS = ""
}
