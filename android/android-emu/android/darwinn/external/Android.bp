cc_library_static {
    name: "libdarwinn_layer_builder",
    defaults: ["neuralnetworks_defaults"],
    proprietary: true,
    srcs: [
        "src/platforms/darwinn/model/layer_builder.cc",
    ],
    local_include_dirs: [ "include" ],
    shared_libs: [
        "libbase",
        "libprotobuf-cpp-full",
    ],
    cppflags: [
        "-DDARWINN_PORT_ANDROID_SYSTEM=1",
        "-Wno-sign-compare",
    ],
    generated_headers: [
        "darwinn_compiler_protos_gen_headers",
    ],
    export_include_dirs: ["include"],
}

cc_defaults {
    name: "darwinn_driver_defaults",
    cppflags: ["-DDARWINN_PORT_ANDROID_SYSTEM=1"],
    proprietary: true,
    header_libs: [ "darwinn_g3_headers" ],
    shared_libs: [
        "libbase",
    ],
}

cc_library_headers {
    name: "darwinn_g3_headers",
    proprietary: true,
    export_include_dirs: [ "include", "generated" ],
}

cc_library_headers {
    name: "darwinn_api_headers",
    export_include_dirs: [ "generated/third_party/darwinn/api" ],
}

subdirs = [
    "src"
]
