        "id": 1099352
      },
      "writtenOn": "2016-08-01T18:12:10Z",
      "side": 1,
      "message": "Is there a reference somewhere that defines this little language?  I\u0027d like to know better how to read this, and how this information is used.",
      "range": {
        "startLine": 49,
        "startChar": 0,
        "endLine": 49,
        "endChar": 15
      },
      "revId": "b529bec4812e9c40baf7b8b0ced2bbf8f57d4c1d",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
