      "writtenOn": "2016-04-01T22:30:45Z",
      "side": 1,
      "message": "are we sure this function is never called from a UI or qemu loop thread? because if it is, it would hang for quite a while with no response. Most probably user will kill the emulator without waiting for it to recover",
      "range": {
        "startLine": 954,
        "startChar": 17,
        "endLine": 954,
        "endChar": 28
      },
      "revId": "7f5ab31924920eb2f2ba0f611caf9b16fc033d45",
