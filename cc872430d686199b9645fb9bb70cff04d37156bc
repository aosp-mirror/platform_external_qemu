      "writtenOn": "2015-12-23T04:13:41Z",
      "side": 1,
      "message": "in batch files C:path means \u0027path\u0027 on the current directory on drive C:, so the correct result is C:\\%cur_dir%\\home\nin normal applications it\u0027s just a completely invalid path",
      "range": {
        "startLine": 519,
        "startChar": 24,
        "endLine": 519,
        "endChar": 51
      },
      "revId": "cc872430d686199b9645fb9bb70cff04d37156bc",
