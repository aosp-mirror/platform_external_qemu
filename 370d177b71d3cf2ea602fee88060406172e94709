      },
      "lineNbr": 91,
      "author": {
        "id": 1079748
      },
      "writtenOn": "2016-07-21T19:43:56Z",
      "side": 1,
      "message": "As noted in AdbTypes, I\u0027d prefer this function to take ownership of |socket| regardless of errors.",
      "range": {
        "startLine": 91,
        "startChar": 45,
        "endLine": 91,
        "endChar": 55
      },
      "revId": "370d177b71d3cf2ea602fee88060406172e94709",
