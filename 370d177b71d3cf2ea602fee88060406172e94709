      },
      "writtenOn": "2016-07-25T12:16:19Z",
      "side": 1,
      "message": "Actually, this isn\u0027t used anymore, comes from the original code IIRC. I\u0027ll remove it.",
      "parentUuid": "8a91eb63_31df7600",
      "range": {
        "startLine": 89,
        "startChar": 28,
        "endLine": 89,
        "endChar": 38
      },
      "revId": "370d177b71d3cf2ea602fee88060406172e94709",
