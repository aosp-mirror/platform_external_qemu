        "id": 1082465
      },
      "writtenOn": "2016-07-18T18:14:20Z",
      "side": 1,
      "message": "Thanks for catching this! Does this also mean that we don\u0027t have to do this in qemu-setup.cpp? In that case, we could also cleanly (for goldfish sync) make the device operation itself a virtual member.",
      "parentUuid": "faa1580d_0d7d9451",
      "range": {
        "startLine": 41,
        "startChar": 4,
        "endLine": 43,
        "endChar": 23
      },
