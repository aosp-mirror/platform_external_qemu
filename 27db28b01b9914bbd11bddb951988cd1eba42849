    {
      "key": {
        "uuid": "9126a68c_bbdd81f0",
        "filename": "android/android-emu/android/virtualscene/SceneCamera.cpp",
        "patchSetId": 2
      },
      "lineNbr": 98,
      "author": {
        "id": 1082465
      },
      "writtenOn": "2018-08-27T16:05:51Z",
      "side": 1,
      "message": "I guess this highlights deeper issues in the code, and we probably want to sit back and address this later, but qemu-setup will be called in vl.c which is after Qt initializes. We\u0027ve had a lot of tricky bugs because Qt can play with virtual devices and such if clicked fast enough before the emulation setup code is triggered. So it could be possible to construct AutomationController from a different thread than we wanted.\n\nFor the real fix, we might want to somehow disable Qt until after emulation setup, but for this code, it might make sense to decouple getting the automation controller from initializing it, and if we get a null pointer, bail from this function instead of aborting.",
      "range": {
        "startLine": 94,
        "startChar": 0,
        "endLine": 98,
        "endChar": 58
      },
      "revId": "27db28b01b9914bbd11bddb951988cd1eba42849",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": true
    },
    {
      "key": {
