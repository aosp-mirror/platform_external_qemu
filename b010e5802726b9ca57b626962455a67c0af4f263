    {
      "key": {
        "uuid": "59cb714e_5c025c32",
        "filename": "android/android-emu/android/skin/qt/video-player/VideoPlayer.cpp",
        "patchSetId": 39
      },
      "lineNbr": 998,
      "author": {
        "id": 1128849
      },
      "writtenOn": "2017-12-19T22:59:36Z",
      "side": 1,
      "message": "Right now, this play() method is private, so the same instance of video player can play only one file. It can\u0027t play multiple video files.\n\nIt\u0027s  a good observation, and I will make the video player to be able to play multiple videos in future releases.",
      "parentUuid": "18bc567b_27daa3fb",
      "range": {
        "startLine": 998,
        "startChar": 0,
        "endLine": 998,
        "endChar": 29
      },
      "revId": "b010e5802726b9ca57b626962455a67c0af4f263",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
    },
