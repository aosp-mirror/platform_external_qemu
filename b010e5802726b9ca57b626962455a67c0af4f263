      "lineNbr": 998,
      "author": {
        "id": 1082465
      },
      "writtenOn": "2017-12-19T16:23:51Z",
      "side": 1,
      "message": "Looks like this sets up all the state fresh? Any parts we can keep from previous invocations to make playing multiple videos in a row less janky?",
      "range": {
        "startLine": 998,
        "startChar": 0,
        "endLine": 998,
        "endChar": 29
      },
      "revId": "b010e5802726b9ca57b626962455a67c0af4f263",
