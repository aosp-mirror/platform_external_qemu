      },
      "writtenOn": "2017-12-19T16:23:51Z",
      "side": 1,
      "message": "It looks like there are two operaitons we can factor out when using VideoPlayerWaitInfo: the timed wait and the signal. Can we make them explicit methods of VideoPlayerWaitInfo?",
      "range": {
        "startLine": 1195,
        "startChar": 0,
        "endLine": 1203,
        "endChar": 31
      },
      "revId": "b010e5802726b9ca57b626962455a67c0af4f263",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": true
