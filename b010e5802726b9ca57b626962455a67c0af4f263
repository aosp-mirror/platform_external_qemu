    {
      "key": {
        "uuid": "13795b24_c58cb379",
        "filename": "android/android-emu/android/skin/qt/video-player/VideoPlayer.cpp",
        "patchSetId": 39
      },
      "lineNbr": 1193,
      "author": {
        "id": 1128849
      },
      "writtenOn": "2017-12-19T22:59:36Z",
      "side": 1,
      "message": "10 ms is an estimate, I tested a few options, 10 msec is a good choice. The reasoning is we don\u0027t want to read too many frames into the queue, so we wait a bit. In the case of packet queue becomes empty, the Decoder will signal this condition.\n\nIn other words, this 10 msec number is not critical, can be difference choices.",
      "parentUuid": "8e785a97_e8754149",
      "range": {
        "startLine": 1193,
        "startChar": 0,
        "endLine": 1193,
        "endChar": 25
      },
      "revId": "b010e5802726b9ca57b626962455a67c0af4f263",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
    },
