      "lineNbr": 858,
      "author": {
        "id": 1080076
      },
      "writtenOn": "2018-01-08T20:50:49Z",
      "side": 1,
      "message": "this loop could take a while, and it would block the thread it\u0027s running on. There was exactly the same issue with location history playback and we ended up creating a worker loader thread - users tend to increase the amount of data used until the system collapses.",
      "range": {
        "startLine": 858,
        "startChar": 0,
        "endLine": 858,
        "endChar": 41
      },
      "revId": "86bd99c5b796ff5f359438926476387089d49d37",
