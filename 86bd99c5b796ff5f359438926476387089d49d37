    {
      "key": {
        "uuid": "edd81438_d69361a0",
        "filename": "android/android-emu/android/physics/PhysicalModel.cpp",
        "patchSetId": 3
      },
      "lineNbr": 849,
      "author": {
        "id": 1233742
      },
      "writtenOn": "2018-01-08T19:28:00Z",
      "side": 1,
      "message": "This type of loading isn\u0027t really portable.  TargetCommand may have different padding on different platforms, the endianness may not match, enums may be different size, etc.\n\nHave you considered using the Stream API that is used for snapshots?  I think that StdioStream may be just what you need.",
      "range": {
        "startLine": 843,
        "startChar": 0,
        "endLine": 849,
        "endChar": 5
      },
      "revId": "86bd99c5b796ff5f359438926476387089d49d37",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "7e325eb0_6a205907",
        "filename": "android/android-emu/android/physics/PhysicalModel.cpp",
        "patchSetId": 3
      },
      "lineNbr": 849,
      "author": {
        "id": 1080076
      },
      "writtenOn": "2018-01-08T20:50:49Z",
      "side": 1,
      "message": "or you could define a protobuf for the data, then save/load it using the generic interfaces. E.g. android/android-emu/android/snapshot/proto/snapshot.proto and its usage\n\nprotobufs aren\u0027t great for big files though - the docs suggest to not use them for anything that can be over 1 MB in size.",
      "parentUuid": "edd81438_d69361a0",
      "range": {
        "startLine": 843,
        "startChar": 0,
        "endLine": 849,
        "endChar": 5
      },
      "revId": "86bd99c5b796ff5f359438926476387089d49d37",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": true
    },
