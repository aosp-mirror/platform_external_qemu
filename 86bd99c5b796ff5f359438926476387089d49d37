      "unresolved": false
    },
    {
      "key": {
        "uuid": "def8aea5_015114c4",
        "filename": "android/android-emu/android/physics/PhysicalModel.cpp",
        "patchSetId": 3
      },
      "lineNbr": 858,
      "author": {
        "id": 1235311
      },
      "writtenOn": "2018-01-09T20:33:01Z",
      "side": 1,
      "message": "I moved to using protos and we just keep the read stream open so we only ever read one proto out of the file at a time which will avoid issues where very large files might eat up all of our memory, or take a long time to load times.  Performance of loading as needed seems reasonable from testing locally.",
      "parentUuid": "7690f412_67405b31",
      "range": {
        "startLine": 858,
        "startChar": 0,
        "endLine": 858,
        "endChar": 41
      },
