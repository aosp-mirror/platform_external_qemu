      },
      "writtenOn": "2016-02-03T22:19:38Z",
      "side": 1,
      "message": "This should be in slot_requestClose.\n\nA \"container\" object has already been closed by the time we get here.",
      "range": {
        "startLine": 280,
        "startChar": 4,
        "endLine": 280,
        "endChar": 25
      },
      "revId": "8767efd7c623ee8b531ce5eea893d03d1b191926",
