      "author": {
        "id": 1082465
      },
      "writtenOn": "2016-02-03T23:14:38Z",
      "side": 1,
      "message": "I\u0027m putting it in a separate CL\u0027s vl.c and in requestClose/closeEvent. We also run the risk of counting other crashes as exit crashes.",
      "parentUuid": "31fce07c_1306ebff",
