    {
      "key": {
        "uuid": "31fce07c_1306ebff",
        "filename": "android/skin/qt/emulator-qt-window.cpp",
        "patchSetId": 4
      },
      "lineNbr": 280,
      "author": {
        "id": 1080076
      },
      "writtenOn": "2016-02-03T22:55:54Z",
      "side": 1,
      "message": "we need to make sure the function is called on all exit paths.\nSo we need to put it everywhere, just in case.",
      "parentUuid": "3115c084_9e9cadde",
      "range": {
        "startLine": 280,
        "startChar": 4,
        "endLine": 280,
        "endChar": 25
      },
      "revId": "8767efd7c623ee8b531ce5eea893d03d1b191926",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
    },
    {
      "key": {
        "uuid": "11f7dc9a_aa7e7ab7",
        "filename": "android/skin/qt/emulator-qt-window.cpp",
        "patchSetId": 4
      },
      "lineNbr": 280,
      "author": {
        "id": 1082465
      },
      "writtenOn": "2016-02-03T23:14:38Z",
      "side": 1,
      "message": "slot_requestClose is not called if the close button is pressed, but it does call closeEvent.\n\nOverall, cmd+q and ctrl-c both call requestClose, but the X button does not.\n\n(OS X btw)",
      "parentUuid": "3115c084_9e9cadde",
      "range": {
        "startLine": 280,
        "startChar": 4,
        "endLine": 280,
        "endChar": 25
      },
      "revId": "8767efd7c623ee8b531ce5eea893d03d1b191926",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
    },
    {
      "key": {
