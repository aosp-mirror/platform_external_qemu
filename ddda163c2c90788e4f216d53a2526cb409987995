      },
      "writtenOn": "2018-04-09T15:59:55Z",
      "side": 1,
      "message": "bool should_split \u003d mapping_changing;  // or removing || mapping_changing\n\nNote that the removing check isn\u0027t necessary (but helps readability) since it implies a flags change, thus a mapping change.",
      "revId": "ddda163c2c90788e4f216d53a2526cb409987995",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": true
