      },
      "lineNbr": 27,
      "author": {
        "id": 1000411
      },
      "writtenOn": "2014-02-14T16:22:51Z",
      "side": 1,
      "message": "I\u0027d recommend another name, since a write here doesn\u0027t \"get\" anything, e.g. PDEV_BUS_SET_NAME_ADDR_HIGH",
      "revId": "d80391eba0f4c6a247957834e8bb6879801013c4",
