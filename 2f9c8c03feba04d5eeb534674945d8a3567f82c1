    {
      "key": {
        "uuid": "fd05bcfe_1f6187de",
        "filename": "android/crashreport/crash-handler.h",
        "patchSetId": 2
      },
      "lineNbr": 57,
      "author": {
        "id": 1087048
      },
      "writtenOn": "2016-02-08T18:10:43Z",
      "side": 1,
      "message": "I guess I\u0027m worried that on some platforms the size of a C++ bool isn\u0027t going to line up with the size of whatever bool is typedeffed to in C. I guess since we have crashhandler_init return a bool it\u0027s not an issue in the compilers we currently use, but judging by a few search results it seems like it might be an issue with VC++ for example. Even if we\u0027ll never change compilers I think we should stick with well defined behavior that won\u0027t cause any surprises in the future. If using bool here is well defined I would be happy to change it though.",
      "parentUuid": "5174f47a_9b455353",
      "range": {
        "startLine": 57,
        "startChar": 0,
        "endLine": 57,
        "endChar": 3
      },
