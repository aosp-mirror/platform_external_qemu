        "id": 1125918
      },
      "writtenOn": "2019-12-05T21:16:48Z",
      "side": 1,
      "message": "What if multiple async commands are running? Could we use a detached std::thread?",
      "revId": "6baae5c17227ce0e3233e746fa0710cee5b091e3",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
