      },
      "lineNbr": 252,
      "author": {
        "id": 1087303
      },
      "writtenOn": "2019-12-05T22:00:16Z",
      "side": 1,
      "message": "Running more than 1 thread makes synchronization non-trivial. It would require us to implement a server here. Let\u0027s not worry about it until we have a use case for it (especially when this function might be removed)",
      "parentUuid": "5d769f20_0b8759d9",
      "revId": "6baae5c17227ce0e3233e746fa0710cee5b091e3",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": true
    },
    {
