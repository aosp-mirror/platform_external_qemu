      "writtenOn": "2016-04-01T18:48:29Z",
      "side": 1,
      "message": "Aaarf, this calls for a new mode kIPv4orIPv6 then, I\u0027ll see what I can do. Would this be the default. What kind of errno value should we check for though?",
      "parentUuid": "2ec1e019_f38e28ed",
      "range": {
        "startLine": 121,
        "startChar": 15,
        "endLine": 121,
        "endChar": 25
      },
      "revId": "a62928ab5e9d8c72d1d23fa11345242844618106",
