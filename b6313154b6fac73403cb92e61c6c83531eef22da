      "key": {
        "uuid": "c111724b_825cc351",
        "filename": "android/android-grpc/emulator_controller.proto",
        "patchSetId": 2
      },
      "lineNbr": 889,
      "author": {
        "id": 1125918
      },
      "writtenOn": "2020-12-07T23:55:07Z",
      "side": 1,
      "message": "There\u0027s no real good support for that in Protobuf: https://stackoverflow.com/questions/26810188/protocol-buffers-and-enums-combinations. Furthermore these flags are secretly dependent on which api level is running in the guest.\n\nWe can include the values in the documentation.",
      "parentUuid": "6fd5f15d_8f798ff4",
      "range": {
        "startLine": 889,
        "startChar": 11,
        "endLine": 889,
        "endChar": 16
      },
      "revId": "b6313154b6fac73403cb92e61c6c83531eef22da",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889"
    },
