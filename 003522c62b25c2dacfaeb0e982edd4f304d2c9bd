      "writtenOn": "2018-08-20T20:20:29Z",
      "side": 1,
      "message": "To be consistent with other usages of LazyInstance in the codebase, and to save a bit of time spent including headers, perhaps we could declare the LazyInstance as a static global in this file and not have to have the friend class declaration and the extra include in the header.",
      "range": {
        "startLine": 29,
        "startChar": 0,
        "endLine": 29,
        "endChar": 56
      },
      "revId": "003522c62b25c2dacfaeb0e982edd4f304d2c9bd",
