    {
      "key": {
        "uuid": "e2b0b90b_1ec0e9f2",
        "filename": "android/skin/qt/size-tweaker.cpp",
        "patchSetId": 2
      },
      "lineNbr": 159,
      "author": {
        "id": 1078773
      },
      "writtenOn": "2016-02-20T02:36:58Z",
      "side": 1,
      "message": "No, and I don\u0027t think we need to. I don\u0027t think any actual redrawing happens until a paintEvent is delivered (i.e. the call to \"move\" doesn\u0027t actually redraw anything, buts \"schedules\" it to be redrawn). I might be wrong about this, but my assertion is supported by the fact that when the widget is rescaled (for example, when dragging between two monitors of different density), I see no flicker, and everything is resized at once.",
      "parentUuid": "82bb7df1_786b815f",
      "range": {
        "startLine": 159,
        "startChar": 11,
        "endLine": 159,
        "endChar": 15
      },
      "revId": "541b136343a2eb074af44919c37be7ca8dd13028",
