      "writtenOn": "2017-10-04T17:54:38Z",
      "side": 1,
      "message": "is it possible to make |agent| a parameter of the ctor? So there\u0027s no time when class is in constructed but invalid state",
      "range": {
        "startLine": 39,
        "startChar": 4,
        "endLine": 39,
        "endChar": 60
      },
      "revId": "ef0fa2028cca53cc217d1b9481e5b2b53cb8edab",
