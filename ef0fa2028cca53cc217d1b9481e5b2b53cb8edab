    {
      "key": {
        "uuid": "cd0cdd9d_eb41863d",
        "filename": "android/android-emu/android/inertialmodel/InertialModel.h",
        "patchSetId": 7
      },
      "lineNbr": 39,
      "author": {
        "id": 1235311
      },
      "writtenOn": "2017-10-04T19:04:22Z",
      "side": 1,
      "message": "The virtual sensors page does not have the agent at construction, so having the agent set in the constructor would force the inertial model to have a different lifetime than the sensors page (and not be a member value) and would add complication there.  Testing the agent for null before sending off sensor data is the same method that the virtual sensors page uses.",
      "parentUuid": "c811c0f9_289ccc96",
      "range": {
        "startLine": 39,
        "startChar": 4,
        "endLine": 39,
        "endChar": 60
      },
      "revId": "ef0fa2028cca53cc217d1b9481e5b2b53cb8edab",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
    },
