      },
      "lineNbr": 162,
      "author": {
        "id": 1152904
      },
      "writtenOn": "2020-03-02T19:53:00Z",
      "side": 1,
      "message": "Which of the options, SHUTDOWN or TERMINATE, is equivalent to clicking the X button in the standalone Emulator\u0027s toolbar?",
      "parentUuid": "f7e4d74e_59422a71",
      "range": {
        "startLine": 162,
        "startChar": 4,
        "endLine": 162,
        "endChar": 12
      },
      "revId": "69627802ab8c078b225d7ef68cee373df34b64a5",
