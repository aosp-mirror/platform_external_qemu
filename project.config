[receive]
	requireContributorAgreement = true
[submit]
	action = merge always
	mergeContent = true
[project]
[access]
	inheritFrom = Platform-Unrestricted-Projects
[access "refs/heads/tools_r20"]
	label-Verified = -1..+1 group Android Maintainers
	submit = group Android Maintainers
[access "refs/heads/tools_r21"]
	label-Verified = -1..+1 group Android Maintainers
	submit = group Android Maintainers
[access "refs/heads/tools_r21.1"]
	label-Verified = -1..+1 group Android Maintainers
	rebase = group Android Maintainers
[access "^refs/heads/qemu-.*"]
	create = group pushers-qemu
	forgeAuthor = group pushers-qemu
	forgeCommitter = group pushers-qemu
	push = group pushers-qemu
	pushMerge = group pushers-qemu
[access "refs/heads/emu-master-dev"]
	forgeAuthor = group emu-dev
	forgeCommitter = group emu-dev
	pushMerge = group emu-dev
