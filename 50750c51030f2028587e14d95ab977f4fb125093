      },
      "lineNbr": 67,
      "author": {
        "id": 1082465
      },
      "writtenOn": "2016-07-20T19:17:25Z",
      "side": 1,
      "message": "I\u0027ll use it to track sync thread construction/destruction for memleak fixing / debugging purposes. It\u0027s been made more clear (moved to the static function for getting/destroying sync threads)",
      "parentUuid": "6a6037e5_f840083c",
      "range": {
        "startLine": 67,
        "startChar": 11,
        "endLine": 67,
        "endChar": 17
      },
