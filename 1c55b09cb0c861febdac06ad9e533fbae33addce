      "writtenOn": "2016-06-13T17:19:54Z",
      "side": 1,
      "message": "Here and below, if we\u0027re going to do the cast to/from char*...why not make this type char* data?  Some external constraint?",
      "range": {
        "startLine": 48,
        "startChar": 44,
        "endLine": 48,
