    },
    {
      "key": {
        "uuid": "b47a9131_b4e246db",
        "filename": "distrib/android-emugl/shared/OpenglCodecCommon/GLDecoderContextData.h",
        "patchSetId": 1
      },
      "lineNbr": 48,
      "author": {
        "id": 1080076
      },
      "writtenOn": "2016-06-15T15:34:16Z",
      "side": 1,
      "message": "void* is a universal idea of pointer to anything, while char* is a pointer to raw bytes (IMHO).",
      "parentUuid": "8f09f4df_0f60f58a",
      "range": {
        "startLine": 48,
        "startChar": 44,
        "endLine": 48,
        "endChar": 54
      },
      "revId": "1c55b09cb0c861febdac06ad9e533fbae33addce",
