    {
      "key": {
        "uuid": "99f12aa5_11b38e6e",
        "filename": "android/base/files/IniFile.h",
        "patchSetId": 4
      },
      "lineNbr": 50,
      "author": {
        "id": 1079748
      },
      "writtenOn": "2015-10-15T22:55:44Z",
      "side": 1,
      "message": "Mmm.. Not really. \nThe IniFile in all of its usecases is really an object with a backing file. You\u0027d mostly create the object with the backing file.\n\nThis is especially true in the way I\u0027m going to use it for metrics -- you create an IniFile object that gets automatically flushed to disk regularly. Then, you just keep dropping metrics into the object and forget about it.\n\nI\u0027ve also added a |writeIfChanged| function now, which will help update the backing file as we go.",
      "parentUuid": "ff32061b_de2bd418",
      "range": {
        "startLine": 42,
        "startChar": 0,
        "endLine": 50,
        "endChar": 38
      },
      "revId": "3c2c56b6a225ba0ac507b7fb8f978a51786535f9",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
