      "lineNbr": 50,
      "author": {
        "id": 1080076
      },
      "writtenOn": "2015-10-14T16:38:12Z",
      "side": 1,
      "message": "it feels more natural to me that we should pass the file name to the read() and write*() methods, not into ini file\u0027s constructor.",
      "range": {
        "startLine": 42,
        "startChar": 0,
        "endLine": 50,
