      "writtenOn": "2015-10-14T16:38:12Z",
      "side": 1,
      "message": "template \u003cclass T\u003e\nT get() ?\n\nget\u003cint\u003e, get\u003cstring\u003e, ... are simpler, easier to generalize and to extend",
      "range": {
        "startLine": 70,
        "startChar": 2,
        "endLine": 74,
        "endChar": 72
      },
      "revId": "3c2c56b6a225ba0ac507b7fb8f978a51786535f9",
