        "id": 1079203
      },
      "writtenOn": "2015-11-30T17:09:51Z",
      "side": 1,
      "message": "This is not a mathematical rotation of 90 degrees, but a rotation of 90 degrees clockwise. I would strongly prefer that we stick to standard mathematical convention.",
      "range": {
        "startLine": 28,
        "startChar": 8,
        "endLine": 29,
        "endChar": 20
      },
      "revId": "1d535b3a9fae1e730823a5d644a71e3043d073e3",
