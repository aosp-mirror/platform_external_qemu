        "id": 1078059
      },
      "writtenOn": "2015-11-30T17:59:37Z",
      "side": 1,
      "message": "My opinion is that having a single direction of rotation is more important than following the mathematical convention. We just need to make it clear that we\u0027re using clockwise rotations *everywhere*. The alternative is to indicate whether a rotation is clockwise or counterclockwise every time we do a rotation.",
      "parentUuid": "fbde9f59_4bdda52d",
      "range": {
        "startLine": 28,
        "startChar": 8,
        "endLine": 29,
        "endChar": 20
      },
      "revId": "1d535b3a9fae1e730823a5d644a71e3043d073e3",
