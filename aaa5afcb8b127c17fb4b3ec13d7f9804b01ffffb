      "writtenOn": "2017-04-12T03:25:37Z",
      "side": 1,
      "message": "this needs to make sure it sends the data buffer by buffer, as pipe driver can split even a 2-byte buffer in half if it happens to lay across two different physical memory pages. Please use the pattern other pipe implementations use - loop over the buffers and copy data chunk-by-chunk",
      "range": {
        "startLine": 78,
        "startChar": 62,
        "endLine": 78,
        "endChar": 71
      },
      "revId": "aaa5afcb8b127c17fb4b3ec13d7f9804b01ffffb",
