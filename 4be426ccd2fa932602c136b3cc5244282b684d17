      "writtenOn": "2016-05-06T22:04:04Z",
      "side": 1,
      "message": "Thanks for the tips Yurii and Bjoern :) investigation + revisions incoming.",
      "parentUuid": "0d22678a_48f05fdb",
      "range": {
        "startLine": 130,
        "startChar": 0,
        "endLine": 134,
        "endChar": 54
      },
      "revId": "4be426ccd2fa932602c136b3cc5244282b684d17",
