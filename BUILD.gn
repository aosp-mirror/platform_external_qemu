# android-qemu2-glue/build/Makefile.qemu2-target.mk
# Rules to build the final target-specific QEMU2 binaries from sources.

# A library that contains all QEMU2 target-specific sources, excluding
# anything implemented by the glue code.

# QEMU2_TARGET = x86
# QEMU2_TARGET_CPU_x86 = i386
# QEMU2_TARGET_TARGET = i386

template("qemu_target") {
  _target = invoker.target
  _arch = invoker.arch

  _sources = invoker.sources

  # store a copy of the top target name, don't use ${target_name} directly
  name = "${target_name}"

  # QEMU2_SYSTEM_CFLAGS
  # QEMU2_SYSTEM_INCLUDES
  config("qemu2_system_config-$name") {
    cflags = [
      "-DNEED_CPU_H",
    ]

    include_dirs = [
      "$QEMU2_DEPS_TOP_DIR/include",
      "tcg",
      "tcg/i386",
    ]

    # from QEMU2_SYSTEM_LDLIBS

    lib_dirs = [
      # QEMU2_SYSTEM_LDFLAGS
      "$QEMU2_DEPS_TOP_DIR/lib",
    ]

    ldflags = [
      QEMU2_GLIB_LDLIBS,
      QEMU2_PIXMAN_LDLIBS,
      "-lfdt",
    ]

    if (is_linux) {
      include_dirs += [
        "linux-headers",
      ]

      ldflags += [
        "-lpthread",
        "-lrt",
       "-lpulse",
      ]
    }

    if (is_mac) {
      ldflags += [
        "-liconv",
        "-lintl",
        "-weak_framework Hypervisor"
      ]
    }

    if (is_win) {
      ldflags += [
        "-lole32",
        "-lvfw32",
        "-ldxguid",
      ]
    }

    configs = [
      ":qemu2_config",
    ]
  }

  static_library("libqemu2-system-$name") {

    sources = QEMU2_TARGET_SOURCES
    sources += _sources

    if (_target == "arm64") {
      sources += [
        "$QEMU2_AUTO_GENERATED_DIR/gdbstub-xml-arm64.c",
      ]
    }
    else if (_target == "arm") {
      sources += [
        "$QEMU2_AUTO_GENERATED_DIR/gdbstub-xml-arm.c",
      ]
    }
    else {
      sources += [
        "stubs/gdbstub.c",
      ]
    }

    sources += [
      "stubs/arch-query-cpu-model-baseline.c",
      "stubs/arch-query-cpu-model-comparison.c",
      "stubs/target-get-monitor-def.c",
    ]

    if (_target == "arm" || _target == "arm64" || 
        _target == "mips" || _target == "mips64") {
      sources += [
        "stubs/arch-query-cpu-model-expansion.c",
        "stubs/qmp_pc_dimm_device_list.c",
        "stubs/vmgenid.c",
      ]
    }

    if (_target != "x86" && _target != "x86_64") {
      sources += [
        "stubs/pc_madt_cpu_entry.c",
        "hw/smbios/smbios_type_38-stub.c",
        "stubs/target-monitor-defs.c",
      ]
    }

    if (_target == "mips" || _target == "mips64") {
      sources += [
        "stubs/dump.c",
        "stubs/arch-query-cpu-def.c",
      ]
    }
  
    if (_target == "x86" || _target == "x86_64") {
      if (is_linux) {
        sources += [
          "hax-stub.c",
        ]
      }
      if (is_linux || is_win) {
        sources += [
          "hvf-stub.c",
        ]
      }

      if (is_linux || is_mac) {
        sources += [
          "whpx-stub.c",
        ]
      }
    } 
    else {
      sources += [
        "hax-stub.c",
        "hvf-stub.c",
        "whpx-stub.c",
      ]
    }

    # TODO
    #LOCAL_PREBUILTS_OBJ_FILES += \
    #$(call qemu2-if-windows,$(QEMU2_AUTO_GENERATED_DIR)/version.o)

    print("target: target-$_target")

    include_dirs = [
      "android-qemu2-glue/config/target-$_target",
      "target/$_arch",
    ]

    if (_target == "arm" || _target == "arm64") {
      include_dirs += [
        "disas/libvixl",
      ]
    }

    configs += [
      ":qemu2_system_config-$name",
    ]
  }

  executable("qemu-upstream-$name") {
    sources = [
      "ui/sdl2.c",
      "ui/sdl2-input.c",
      "ui/sdl2-2d.c",
      "vl.c",
    ]

    if (_target == "x86" || _target == "x86_64") {
      sources += [
        "hw/i386/acpi-build.c",
        "hw/i386/pc_piix.c",
      ]
    }

    if (is_win) {
      sources += [
        "stubs/win32-stubs.c",
      ]
    }
  
    output_dir = "$root_out_dir/qemu/$BUILD_TARGET_TAG"

    include_dirs = [
      "android-qemu2-glue/config/target-$_target",
      "target/$_arch",
      QEMU2_SDL2_INCLUDES
    ]

    configs += [
      ":qemu2_system_config-$name",
      "//external/qemu/android/third_party:zlib",
    ]

    if (is_linux) {
      configs += [
        "//external/qemu/android/third_party:libusb",
        "//external/qemu/android/third_party:libbluez",
      ]
    }

    ldflags = [
      "-lSDL2",
    ]

    if (!is_mac) {
      ldflags += [
        "-lSDL2main"
      ]
    }

    if (is_win) {
      ldflags += [
        "-limm32",
        "-ldinput8",
        "-ldxguid",
        "-ldxerr8",
        "-luser32",
        "-lgdi32",
        "-lwinmm",
        "-lole32",
        "-loleaut32",
        "-lshell32",
        "-lversion",
        "-luuid",
      ]
    }
    else {
      ldflags += [
        "-ldl",
      ]
    }

    deps = [
      ":libqemu2-common",
      ":libqemu2-system-$name",
    ]
  }

  # The emulator-specific version of QEMU2, with CONFIG_ANDROID defined at
  # compile-time.
  executable("qemu-system-$name") {
    sources = [
      "android-qemu2-glue/main.cpp",
      "vl.c",
    ]

    if (_target == "x86" || _target == "x86_64") {
      sources += [
        "hw/i386/acpi-build.c",
        "hw/i386/pc_piix.c",
      ]
    }

    if (is_win) {
      sources += [
        "android-qemu2-glue/stubs/win32-stubs.c",
      ]
    }

    output_dir = "$root_out_dir/$BUILD_TARGET_TAG"

    cflags = [
      "-DCONFIG_ANDROID",
    ]

    include_dirs = [
      "android-qemu2-glue/config/target-$_target",
      "target/$_arch",

      # ANDROID_EMU_INCLUDES,
      "//external/qemu/android/android-emu",
      EMUGL_INCLUDES,
    ]

    configs += [
      ":qemu2_system_config-$name",
    ]

    deps = [
      "//build/config:exe_and_shlib_deps",
      "//build/win:default_exe_manifest",
      "//third_party/protobuf:protobuf_full",

      ":libqemu2-common",
      ":libqemu2-glue",
      ":libqemu2-system-$name",
      "//external/qemu/android/android-emu:android-emu-base",
      "//external/qemu/android/android-emu:android-emu",
      "//external/qemu/android/android-emu:emulator-libui",
    ]
  }
}

