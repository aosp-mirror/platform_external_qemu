import("//third_party/protobuf/proto_library.gni")
import("android/config.gni")
import("sources.gni")

BUILD_OBJS_DIR = "//external/qemu/objs"

QEMU2_AUTO_GENERATED_DIR = "$BUILD_OBJS_DIR/build/qemu2-qapi-auto-generated"

qemu2_auto_generated_dir = "$target_gen_dir/qemu2-qapi-auto-generated"

QEMU2_DEPS_TOP_DIR = "$QEMU2_DEPS_PREBUILTS_DIR/$BUILD_TARGET_TAG"

QEMU2_GLIB_INCLUDES = [
  "$QEMU2_DEPS_TOP_DIR/include/glib-2.0",
  "$QEMU2_DEPS_TOP_DIR/lib/glib-2.0/include",
]
QEMU2_GLIB_LDLIBS = "-lglib-2.0"

QEMU2_PIXMAN_INCLUDES = "$QEMU2_DEPS_TOP_DIR/include/pixman-1"
QEMU2_PIXMAN_LDLIBS = "-lpixman-1"

QEMU2_SDL2_INCLUDES = "$QEMU2_DEPS_TOP_DIR/include/SDL2"

# Ensure config-host.h can be found properly.
QEMU2_INCLUDES = [
  "android-qemu2-glue/config/$BUILD_TARGET_TAG",
]

if (is_linux) {
  QEMU2_INCLUDES += [
    "$QEMU2_TOP_DIR/linux-headers",
  ]
}

# Ensure QEMU2 headers are found.
QEMU2_INCLUDES += [
  ".",
  "include",
  QEMU2_AUTO_GENERATED_DIR,
]

QEMU2_INCLUDES += QEMU2_GLIB_INCLUDES

QEMU2_INCLUDES += [
  QEMU2_PIXMAN_INCLUDES,
]

config("qemu2_config") {

  # copied from QEMU2_CFLAGS

  cflags = EMULATOR_COMMON_CFLAGS

  cflags += [
    "-fno-strict-aliasing",
    "-fno-common",
    "-D_GNU_SOURCE",
    "-D_FILE_OFFSET_BITS=64",
    "-Wno-unused-function",
    "-DCONFIG_MIGRATION_RAM_SINGLE_ITERATION"
  ]

  if (is_win) {
    cflags += [
      "-DWIN32_LEAN_AND_MEAN",
      "-D__USE_MINGW_ANSI_STDIO=1",
      "-mms-bitfields",
     ]
   }

  if (is_mac) {
    cflags += [
      "-Wno-initializer-overrides",
    ]
  }

  if (is_clang) {
    cflags += [
      "-Wno-address-of-packed-member",
      "-Wno-tautological-pointer-compare",
      "-Wno-tautological-compare",
      "-Wno-tautological-pointer-compare",
      "-Wno-format-security",
    ]
  } else {
    cflags += [
      "-Wno-unused-variable",
      "-Wno-unused-but-set-variable",
      "-Wno-maybe-uninitialized",
    ]
  }
  # end of QEMU2_CFLAGS

  include_dirs = QEMU2_INCLUDES
}

