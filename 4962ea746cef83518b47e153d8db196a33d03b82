        "id": 1079748
      },
      "writtenOn": "2016-01-25T23:51:24Z",
      "side": 1,
      "message": "We run two checks in the given interval. /3 allows for enough extra time that if both the checks timeout, we won\u0027t race with the next check.\n\nIn practice, check interval \u003e\u003e reasonable timeout; so not using all the time provided for the checks is OK.",
      "parentUuid": "f4b5d6da_fd024320",
      "range": {
        "startLine": 94,
        "startChar": 15,
        "endLine": 94,
        "endChar": 36
      },
