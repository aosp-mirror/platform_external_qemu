    {
      "key": {
        "uuid": "0e5fa128_5004a456",
        "filename": "hw/android/goldfish/pipe.c",
        "patchSetId": 1
      },
      "lineNbr": 1428,
      "author": {
        "id": 1080076
      },
      "writtenOn": "2015-09-24T16:14:34Z",
      "side": 1,
      "message": "Yes, but it\u0027s not a part of C++, and it wasn\u0027t implemented in MSVC for quite a while. I\u0027d prefer if we didn\u0027t use this kind of not very portable features, but I don\u0027t insist",
      "parentUuid": "eececd75_81bc7af1",
      "range": {
        "startLine": 1427,
        "startChar": 1,
        "endLine": 1428,
        "endChar": 37
      },
      "revId": "670df44fff4d560415ab3f1d632e13f3749624b8",
