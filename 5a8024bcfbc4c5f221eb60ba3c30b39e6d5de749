    {
      "key": {
        "uuid": "b709cdc7_8bc0531c",
        "filename": "android/android-emu/android/snapshot/Snapshotter.cpp",
        "patchSetId": 29
      },
      "lineNbr": 160,
      "author": {
        "id": 1080076
      },
      "writtenOn": "2017-09-13T18:54:10Z",
      "side": 1,
      "message": "|mLoader| gets reset when we begin a saving operation. Checking it here isn\u0027t safe if there\u0027s any chance this callback gets called after a save.\nthe current check good if you want to know if the synchronous part of loading is done. But mLoader-\u003eramLoader() could still be doing async load, or could complete it - and that won\u0027t change mLoader-\u003estatus()\n\ncorrect check IMO is (mLoader \u0026\u0026 status \u003d\u003d Ok \u0026\u0026 (!ramLoader-\u003eonDemandEnabled() || ramLoader-\u003e{new function to check if on demand completed})",
      "range": {
        "startLine": 160,
        "startChar": 21,
        "endLine": 160,
        "endChar": 38
      },
      "revId": "5a8024bcfbc4c5f221eb60ba3c30b39e6d5de749",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
