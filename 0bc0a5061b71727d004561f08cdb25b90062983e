      "writtenOn": "2017-11-14T17:13:36Z",
      "side": 1,
      "message": "I see that saveFailure() also writes the number of successful and invalid loads, so there is new information even if the failure code is the same.\nAlso, is it OK to have the file show the latest error, if the most recent attempt was successful?",
      "parentUuid": "812487f6_0cb0ce6e",
      "range": {
        "startLine": 374,
        "startChar": 4,
        "endLine": 374,
        "endChar": 15
      },
      "revId": "0bc0a5061b71727d004561f08cdb25b90062983e",
