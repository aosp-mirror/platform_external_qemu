    {
      "key": {
        "uuid": "6d7da3ec_dd7567ec",
        "filename": "android/emulation/control/FilePusher.h",
        "patchSetId": 2
      },
      "lineNbr": 67,
      "author": {
        "id": 1078773
      },
      "writtenOn": "2016-05-04T18:10:01Z",
      "side": 1,
      "message": "I have changed the semantics of this class a little bit. Now it is not possible to enqueue files while a push is in progress. That is, you can enqueue a large group of files, using a pair of callbacks, but you must wait until the push completes to enqueue more. So if a file was enqueued with a certain pair of callbacks, that pair is guaranteed to be used with it.",
      "parentUuid": "6d7da3ec_62277a56",
      "range": {
        "startLine": 66,
        "startChar": 0,
        "endLine": 67,
        "endChar": 45
      },
      "revId": "f92cc9f33ee2cd42f716dfe18b4480320757d80d",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
    },
