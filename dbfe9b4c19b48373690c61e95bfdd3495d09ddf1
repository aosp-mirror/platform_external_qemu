    {
      "key": {
        "uuid": "b9985227_0736df85",
        "filename": "android/android-emu/android/recording/video/player/VideoPlayer.cpp",
        "patchSetId": 3
      },
      "lineNbr": 1275,
      "author": {
        "id": 1414904
      },
      "writtenOn": "2019-06-21T08:22:44Z",
      "side": 1,
      "message": "To expand on Jeff\u0027s suggestion, AutoLock allows us to do locking in an RAII manner. This means that we hold the lock upon creation of the AutoLock, and when it goes out of scope (in this case when we go to the next iteration of the while loop), we destroy the lock and thus unlock the mutex.\n\nThis is better than manual locking because we can be certain that every created mutex lock will have a corresponding unlock.",
      "parentUuid": "c53232f4_5bb8a947",
      "range": {
        "startLine": 1264,
        "startChar": 4,
        "endLine": 1275,
        "endChar": 19
      },
